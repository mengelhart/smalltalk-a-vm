# =============================================================================
# Smalltalk/A VM — .gitignore
# Target: C17 / CMake / macOS / Apple clang / arm64
# =============================================================================

# -----------------------------------------------------------------------------
# CMake build artifacts
# -----------------------------------------------------------------------------
build/
cmake-build-*/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
_deps/

# compile_commands.json lives in build/ and is symlinked to root
# The symlink itself is intentionally not tracked
compile_commands.json

# -----------------------------------------------------------------------------
# Compiled output
# -----------------------------------------------------------------------------
*.o
*.a
*.dylib
*.so
*.so.*
*.out

# -----------------------------------------------------------------------------
# clangd cache
# -----------------------------------------------------------------------------
.cache/
.clangd/

# -----------------------------------------------------------------------------
# macOS system files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# Xcode (should not appear in the VM repo, but just in case)
# -----------------------------------------------------------------------------
*.xcodeproj/
*.xcworkspace/
xcuserdata/
DerivedData/
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3

# -----------------------------------------------------------------------------
# Editor and IDE artifacts
# -----------------------------------------------------------------------------

# Emacs
*~
\#*\#
.\#*
*.elc

# Vim / Neovim
*.swp
*.swo
*.swn
.vim/
Session.vim

# VS Code / Cursor
.vscode/
*.code-workspace

# JetBrains
.idea/

# -----------------------------------------------------------------------------
# lldb
# -----------------------------------------------------------------------------
*.dSYM/

# -----------------------------------------------------------------------------
# Instruments / profiling
# -----------------------------------------------------------------------------
*.trace/

# -----------------------------------------------------------------------------
# Test output
# -----------------------------------------------------------------------------
Testing/
LastTest.log
CTestCostData.txt

# -----------------------------------------------------------------------------
# Dependency managers (not used yet, but common to accidentally introduce)
# -----------------------------------------------------------------------------
vcpkg_installed/
conan/

# -----------------------------------------------------------------------------
# Crash reports
# -----------------------------------------------------------------------------
*.crash

# -----------------------------------------------------------------------------
# Temporary / scratch files
# -----------------------------------------------------------------------------
*.tmp
*.bak
scratch/

# Dolt database files (added by bd init)
.dolt/
*.db
